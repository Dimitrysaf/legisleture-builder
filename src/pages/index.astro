---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Συντάκτης Νόμου – Legisleture Builder">
  <div class="drawer lg:drawer-open h-screen" id="nb-app">
    <input id="nb-drawer-toggle" type="checkbox" class="drawer-toggle" checked />

    <!-- Main content -->
    <div class="drawer-content flex flex-col overflow-y-auto">
      <!-- Mobile toolbar toggle -->
      <div class="lg:hidden flex items-center gap-2 px-4 py-2 bg-base-100 border-b border-base-300 sticky top-0 z-10">
        <label for="nb-drawer-toggle" class="btn btn-ghost btn-sm gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          Templates
        </label>
      </div>

      <!-- Mode bar -->
      <div class="nb-mode-bar" id="nb-mode-bar">
        <div class="nb-mode-tabs">
          <button class="nb-mode-tab nb-mode-tab--active" data-mode="edit">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            Επεξεργασία
          </button>
          <button class="nb-mode-tab" data-mode="preview">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            Προεπισκόπηση
          </button>
          <button class="nb-mode-tab" data-mode="code">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            LaTeX
          </button>
        </div>

        <!-- File area (right side of mode bar) -->
        <div class="nb-file-area">
          <span class="nb-save-status" id="nb-save-status" hidden></span>

          <button class="nb-file-btn" id="nb-fek-meta-btn" type="button" title="Στοιχεία ΦΕΚ (τεύχος, αριθμός, ημερομηνία, τίτλος)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
            ΦΕΚ Στοιχεία
          </button>

          <button class="nb-file-btn" id="nb-import-btn" type="button" title="Φόρτωση αρχείου .json ή .tex">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            Εισαγωγή
          </button>

          <div class="nb-dropdown-wrap">
            <button class="nb-file-btn nb-file-btn--primary" id="nb-export-trigger" type="button">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Αποθήκευση / Εξαγωγή
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
            </button>

            <div class="nb-file-menu" id="nb-file-menu" hidden>
              <div class="nb-file-menu-section">Αποθήκευση έργου</div>
              <button class="nb-file-menu-item" data-file-action="save-json">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                Αποθήκευση ως JSON
                <span class="nb-file-menu-ext">.json</span>
              </button>

              <div class="nb-file-menu-sep"></div>
              <div class="nb-file-menu-section">Εξαγωγή</div>

              <button class="nb-file-menu-item" data-file-action="export-html">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                Ιστοσελίδα
                <span class="nb-file-menu-ext">.html</span>
              </button>
              <button class="nb-file-menu-item" data-file-action="export-fek-html">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
                Ιστοσελίδα με ΦΕΚ επικεφαλίδα
                <span class="nb-file-menu-ext">.html</span>
              </button>
              <button class="nb-file-menu-item" data-file-action="export-latex">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                LaTeX
                <span class="nb-file-menu-ext">.tex</span>
              </button>
              <button class="nb-file-menu-item" data-file-action="export-txt">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                Απλό Κείμενο
                <span class="nb-file-menu-ext">.txt</span>
              </button>

              <div class="nb-file-menu-sep"></div>

              <button class="nb-file-menu-item" data-file-action="export-pdf">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                Εκτύπωση / PDF
              </button>
            </div>
          </div>

          <input type="file" id="nb-import-input" accept=".json,.tex,.latex"
            style="position:absolute;width:1px;height:1px;opacity:0;overflow:hidden;clip:rect(0,0,0,0);pointer-events:none;">
        </div>
      </div>

      <!-- Restore session banner -->
      <div class="nb-restore-banner" id="nb-restore-banner" hidden>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
        <span>Βρέθηκε αυτόματη αποθήκευση από <strong class="nb-restore-time"></strong></span>
        <button class="nb-restore-btn nb-restore-btn--yes" id="nb-restore-yes" type="button">Επαναφορά</button>
        <button class="nb-restore-btn" id="nb-restore-dismiss" type="button">Κλείσιμο</button>
      </div>

      <!-- Canvas (edit + preview modes) -->
      <div class="nb-canvas" id="nb-canvas">
        <button class="nb-page-add-btn" id="nb-add-page-top" type="button">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          Νέα Σελίδα πάνω
        </button>
        <div class="nb-paper" id="nb-paper"></div>
        <button class="nb-page-add-btn" id="nb-add-page-bottom" type="button">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          Νέα Σελίδα κάτω
        </button>
      </div>

      <!-- Code panel (code mode) -->
      <div class="nb-code-panel" id="nb-code-panel">
        <div class="nb-code-toolbar">
          <span class="nb-code-label">LaTeX Source</span>
          <div class="nb-code-actions">
            <button class="nb-code-btn" id="nb-code-copy">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
              </svg>
              Αντιγραφή
            </button>
            <button class="nb-code-btn" id="nb-code-download">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
              </svg>
              Λήψη .tex
            </button>
          </div>
        </div>
        <pre class="nb-code-content" id="nb-code-content"></pre>
      </div>
    </div>

    <!-- Sidebar / Toolbar -->
    <div class="drawer-side z-40">
      <label for="nb-drawer-toggle" aria-label="close sidebar" class="drawer-overlay"></label>
      <div id="nb-toolbar" class="flex flex-col w-72 min-h-full bg-base-200 border-r border-base-300"></div>
    </div>
  </div>
</Layout>

<script>
  import '../scripts/builder';
</script>
