---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Συντάκτης Νόμου – Legisleture Builder">
  <div class="drawer lg:drawer-open h-screen" id="nb-app">
    <input id="nb-drawer-toggle" type="checkbox" class="drawer-toggle" checked />

    <!-- Main content -->
    <div class="drawer-content flex flex-col overflow-y-auto">
      <!-- Mobile toolbar toggle -->
      <div class="lg:hidden flex items-center gap-2 px-4 py-2 bg-base-100 border-b border-base-300 sticky top-0 z-10">
        <label for="nb-drawer-toggle" class="btn btn-ghost btn-sm gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          Templates
        </label>
      </div>

      <!-- Canvas -->
      <div class="nb-canvas">
        <div class="nb-paper" id="nb-paper"></div>
      </div>
    </div>

    <!-- Sidebar / Toolbar -->
    <div class="drawer-side z-40">
      <label for="nb-drawer-toggle" aria-label="close sidebar" class="drawer-overlay"></label>
      <div id="nb-toolbar" class="flex flex-col w-72 min-h-full bg-base-200 border-r border-base-300"></div>
    </div>
  </div>
</Layout>

<script>
  import '../scripts/builder';
</script>
