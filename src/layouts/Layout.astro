---
import '../styles/tailwind.css';
import '../styles/main.scss';

interface Props {
  title?: string;
}

const { title = 'Legisleture Builder' } = Astro.props;
---
<!doctype html>
<html lang="el" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif:ital,opsz,wght@0,6..18,400;0,6..18,700;1,6..18,400;1,6..18,700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=GFS+Didot:ital,wght@0,400;1,400&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex flex-col antialiased bg-base-100 font-sans">
    <slot />
  </body>
</html>
