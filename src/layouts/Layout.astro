---
import '../styles/main.scss';
import CookieBanner from '../components/CookieBanner.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Feedback from '../components/Feedback.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title?: string;
  breadcrumbs?: Array<{ text: string; href?: string }>;
}

const { title = 'Legisleture Builder', breadcrumbs } = Astro.props;
---
<!doctype html>
<html lang="el" class="govuk-template">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Sharp:opsz,wght,FILL,GRAD@24,400,1,0" rel="stylesheet" />
    <link rel="preload" href="/gov_gr.svg" as="image" type="image/svg+xml" />
    <link rel="preload" href="/Κυβέρνηση_της_Ελλάδας.svg" as="image" type="image/svg+xml" />
  </head>
  <body class="govuk-template__body">
    <CookieBanner />
    <SiteHeader />
    <main class="govuk-main-wrapper" id="main-content" role="main" tabindex="-1">
      {breadcrumbs && <Breadcrumbs items={breadcrumbs} />}
      <slot />
    </main>
    <Feedback />
    <SiteFooter />
  </body>
</html>
