---
import nav from '../data/navigation.json';
import SearchForm from './SearchForm.astro';
---
<header class="gem-c-layout-super-navigation-header">
  <div class="govuk-width-container gem-c-layout-super-navigation-header__container">
    <a href="/" class="gem-c-layout-super-navigation-header__header-logo" aria-label="gov.gr - Αρχική">
      <div class="gem-c-layout-super-navigation-header__header-logo-inner">
        <img src="/gov_gr.svg" alt="gov.gr" width="141" height="40" fetchpriority="high" decoding="sync" />
      </div>
    </a>
    <nav aria-label="Μενού πλοήγησης" class="gem-c-layout-super-navigation-header__content">
      <button
        type="button"
        id="super-nav-toggle"
        aria-expanded="false"
        aria-controls="super-nav-panel"
        aria-label="Εμφάνιση μενού πλοήγησης"
        class="gem-c-layout-super-navigation-header__navigation-top-toggle-button"
      >
        <span class="gem-c-layout-super-navigation-header__navigation-top-toggle-button-inner">Μενού</span>
      </button>
      <button
        type="button"
        id="super-search-toggle"
        aria-expanded="false"
        aria-controls="super-search-panel"
        aria-label="Εμφάνιση αναζήτησης"
        class="gem-c-layout-super-navigation-header__search-toggle-button"
      >
        <span class="govuk-visually-hidden">Αναζήτηση στο gov.gr</span>
        <svg class="gem-c-layout-super-navigation-header__search-toggle-button-link-icon" width="27" height="27" viewBox="0 0 27 27" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
          <circle cx="12.0161" cy="11.0161" r="8.51613" stroke="currentColor" stroke-width="3"></circle>
          <line x1="17.8668" y1="17.3587" x2="26.4475" y2="25.9393" stroke="currentColor" stroke-width="3"></line>
        </svg>
        <span aria-hidden="true" class="gem-c-layout-super-navigation-header__navigation-top-toggle-close-icon">×</span>
      </button>
      <a class="gem-c-layout-super-navigation-header__search-item-link" href="/search" hidden>
        <span class="govuk-visually-hidden">Αναζήτηση στο gov.gr</span>
        <svg class="gem-c-layout-super-navigation-header__search-item-link-icon" width="27" height="27" viewBox="0 0 27 27" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
          <circle cx="12.0161" cy="11.0161" r="8.51613" stroke="currentColor" stroke-width="3"></circle>
          <line x1="17.8668" y1="17.3587" x2="26.4475" y2="25.9393" stroke="currentColor" stroke-width="3"></line>
        </svg>
      </a>
    </nav>
  </div>

  <!-- Nav dropdown -->
  <div id="super-nav-panel" class="gem-c-layout-super-navigation-header__navigation-dropdown-menu" hidden>
    <div class="govuk-width-container">
      <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds-from-desktop gem-c-layout-super-navigation-header__column--services-and-information">
          <h3 class="govuk-heading-m gem-c-layout-super-navigation-header__column-header">Υπηρεσίες και πληροφορίες</h3>
          <ul class="gem-c-layout-super-navigation-header__navigation-second-items gem-c-layout-super-navigation-header__navigation-second-items--services-and-information">
            {nav.services.map(item => (
              <li class="gem-c-layout-super-navigation-header__dropdown-list-item">
                <a class="govuk-link gem-c-layout-super-navigation-header__navigation-second-item-link" href={item.href}>{item.text}</a>
              </li>
            ))}
          </ul>
        </div>
        <div class="govuk-grid-column-one-third-from-desktop gem-c-layout-super-navigation-header__column--government-activity">
          <h3 class="govuk-heading-m gem-c-layout-super-navigation-header__column-header">Δραστηριότητα</h3>
          <ul class="gem-c-layout-super-navigation-header__navigation-second-items">
            {nav.government.map(item => (
              <li class="gem-c-layout-super-navigation-header__dropdown-list-item">
                <a class="govuk-link gem-c-layout-super-navigation-header__navigation-second-item-link gem-c-layout-super-navigation-header__navigation-second-item-link--with-description" href={item.href}>{item.text}</a>
                <p class="gem-c-layout-super-navigation-header__navigation-second-item-description">{item.description}</p>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- Search dropdown -->
  <div id="super-search-panel" class="gem-c-layout-super-navigation-header__navigation-dropdown-menu" hidden>
    <div class="govuk-width-container gem-c-layout-super-navigation-header__search-container gem-c-layout-super-navigation-header__search-items">
      <h3 class="govuk-visually-hidden">Αναζήτηση</h3>
      <div class="govuk-grid-row">
        <div class="govuk-grid-column-full">
          <SearchForm
            id="header-search-input"
            label="Αναζήτηση στο gov.gr"
            onWhite={true}
          />
        </div>
      </div>
    </div>
  </div>

  <script>
    const superNavToggle    = document.getElementById('super-nav-toggle')!;
    const superNavPanel     = document.getElementById('super-nav-panel')!;
    const superSearchToggle = document.getElementById('super-search-toggle')!;
    const superSearchPanel  = document.getElementById('super-search-panel')!;

    function closeNav() {
      superNavPanel.setAttribute('hidden', '');
      superNavToggle.setAttribute('aria-expanded', 'false');
      superNavToggle.setAttribute('aria-label', 'Εμφάνιση μενού πλοήγησης');
      superNavToggle.classList.remove('gem-c-layout-super-navigation-header__open-button');
    }

    function closeSearch() {
      superSearchPanel.setAttribute('hidden', '');
      superSearchToggle.setAttribute('aria-expanded', 'false');
      superSearchToggle.setAttribute('aria-label', 'Εμφάνιση αναζήτησης');
      superSearchToggle.classList.remove('gem-c-layout-super-navigation-header__open-button');
    }

    superNavToggle.addEventListener('click', () => {
      const open = superNavToggle.getAttribute('aria-expanded') === 'true';
      closeSearch();
      if (open) { closeNav(); } else {
        superNavPanel.removeAttribute('hidden');
        superNavToggle.setAttribute('aria-expanded', 'true');
        superNavToggle.setAttribute('aria-label', 'Απόκρυψη μενού πλοήγησης');
        superNavToggle.classList.add('gem-c-layout-super-navigation-header__open-button');
      }
    });

    superSearchToggle.addEventListener('click', () => {
      const open = superSearchToggle.getAttribute('aria-expanded') === 'true';
      closeNav();
      if (open) { closeSearch(); } else {
        superSearchPanel.removeAttribute('hidden');
        superSearchToggle.setAttribute('aria-expanded', 'true');
        superSearchToggle.setAttribute('aria-label', 'Απόκρυψη αναζήτησης');
        superSearchToggle.classList.add('gem-c-layout-super-navigation-header__open-button');
        document.getElementById('header-search-input')?.focus();
      }
    });

    document.addEventListener('click', (e) => {
      const header = document.querySelector('.gem-c-layout-super-navigation-header');
      if (!header?.contains(e.target as Node)) { closeNav(); closeSearch(); }
    });
  </script>
</header>
